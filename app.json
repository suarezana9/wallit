{
  "expo": {
    "name": "Wallit",
    "slug": "wallit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "wallit",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wallit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Para escanear tickets y facturas",
        "NSMicrophoneUsageDescription": "Para cargar gastos por voz",
        "NSFaceIDUsageDescription": "Para proteger gastos privados"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C47FF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.wallit.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Para cargar gastos por voz"
        }
      ],
      "expo-local-authentication",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/wallit"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f02f7c6-6dba-4b9c-b38e-299c4374e42d"
      }
    }
  }
}
